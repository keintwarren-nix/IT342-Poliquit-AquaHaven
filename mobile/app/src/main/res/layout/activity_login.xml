<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_aqua"
        android:scaleType="centerCrop"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000"/>

    <androidx.cardview.widget.CardView
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:background="#FFFFFF">

            <!-- Logo centered and large -->
            <ImageView
                android:layout_width="200dp"
                android:layout_height="80dp"
                android:src="@drawable/logo_aqua"
                android:scaleType="fitCenter"
                android:layout_gravity="center"
                android:layout_marginBottom="6dp"/>

            <!-- Title -->
            <TextView
                android:text="Welcome Back"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"/>

            <!-- Subtitle -->
            <TextView
                android:text="Sign in to access your account and shop our collection."
                android:textSize="12sp"
                android:textColor="#777777"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"/>

            <!-- Email Label -->
            <TextView
                android:text="EMAIL ADDRESS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#444444"
                android:letterSpacing="0.1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"/>

            <!-- Email Field -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_outline"
                android:inputType="textEmailAddress"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Password Label -->
            <TextView
                android:text="PASSWORD"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#444444"
                android:letterSpacing="0.1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"/>

            <!-- Password Field -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_outline"
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <!-- Sign In Button -->
            <Button
                android:id="@+id/btnLogin"
                android:text="Sign In"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="#111111"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Message -->
            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"/>

            <!-- Go Register -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:text="Don't have an account? "
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvGoRegister"
                    android:text="Create one now"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>